  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Pre-request a nivel coleccion: inyecta el token JWT en el header Authorization",
          "// en cada request que se ejecute. Si el token esta vacio, no agrega el header.",
          "const token = pm.environment.get('jwt_token') || '';",
          "if (token.trim().length > 0) {",
          "    pm.request.headers.upsert({",
          "        key: 'Authorization',",
          "        value: 'Bearer ' + token.trim()",
          "    });",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "Autenticacion",
      "description": "Ejecutar primero 'Login Admin - Guarda Token'. El token ADMIN se usa en toda la coleccion automaticamente.",
      "item": [
        {
          "name": "Login Admin - Guarda Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const token = (pm.response.text() || '').trim();",
                  "if (token.length > 0) {",
                  "    pm.environment.set('jwt_token', token);",
                  "    console.log('Token ADMIN guardado correctamente en jwt_token.');",
                  "    pm.test('Login Admin exitoso - Token recibido', function () {",
                  "        pm.response.to.have.status(200);",
                  "    });",
                  "} else {",
                  "    console.error('ERROR: No se recibio token. Verificar XAMPP/MySQL y que exista el usuario admin (DataSeedingConfig).');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@tienda.com\",\n  \"password\": \"admin123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "localhost:8080/api/auth/login",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "login"]
            }
          },
          "response": []
        }
      ]
    },
